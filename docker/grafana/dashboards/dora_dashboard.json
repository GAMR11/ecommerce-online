{
  "title": "DASHBOARD DE METRICAS DORA",
  "panels": [
    {
      "title": "Deployment Frequency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT timestamp AS time, count(*) as value FROM metrics WHERE type = 'deployment-result' AND JSON_EXTRACT(data, '$.is_failure') = false GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Lead Time for Changes (Minutos)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT avg(CAST(JSON_EXTRACT(data, '$.lead_time_seconds') AS UNSIGNED) / 60) FROM metrics WHERE type = 'leadtime'",
          "format": "table"
        }
      ]
    },
    {
      "title": "Change Failure Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "type": "gauge",
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 15},
              {"color": "red", "value": 30}
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT (SUM(CASE WHEN JSON_EXTRACT(data, '$.is_failure') = true THEN 1 ELSE 0 END) / COUNT(*)) * 100 FROM metrics WHERE type = 'deployment-result'",
          "format": "table"
        }
      ]
    },
    {
      "title": "Mean Time to Recovery (MTTR - Minutos)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "type": "stat",
      "description": "Tiempo promedio para resolver incidentes",
      "targets": [
        {
          "rawSql": "SELECT AVG(CAST(JSON_EXTRACT(data, '$.duration_minutes') AS UNSIGNED)) FROM metrics WHERE type = 'incident' AND JSON_EXTRACT(data, '$.status') = 'resolved'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "0" } } }
          ]
        }
      }
    }
  ]
}